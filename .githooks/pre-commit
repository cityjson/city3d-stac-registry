#!/bin/sh
#
# Pre-commit hook for cityjson-stac
# Runs formatting and linting checks before allowing commits
#
# To install: ./scripts/setup-hooks.sh
# To bypass (emergency): git commit --no-verify

set -e

echo "🔍 Running pre-commit checks..."

# Check if cargo is available
if ! command -v cargo > /dev/null 2>&1; then
    echo "❌ cargo not found. Please install Rust: https://rustup.rs"
    exit 1
fi

# Store the current directory
ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

# Get list of staged Rust files
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.rs$' || true)

if [ -z "$STAGED_RS_FILES" ]; then
    echo "✅ No Rust files staged, skipping checks"
    exit 0
fi

echo "📝 Checking formatting..."
if ! cargo fmt --all -- --check; then
    echo ""
    echo "❌ Formatting issues found!"
    echo "   Run 'cargo fmt' to fix them, then stage the changes."
    exit 1
fi
echo "✅ Formatting OK"

echo "🔎 Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo ""
    echo "❌ Clippy found issues!"
    echo "   Fix the warnings above before committing."
    exit 1
fi
echo "✅ Clippy OK"

echo "🧪 Running quick tests..."
if ! cargo test --lib 2>/dev/null; then
    echo ""
    echo "❌ Tests failed!"
    echo "   Fix failing tests before committing."
    exit 1
fi
echo "✅ Tests OK"

echo ""
echo "✅ All pre-commit checks passed!"
