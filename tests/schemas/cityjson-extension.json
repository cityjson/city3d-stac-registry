{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stac-extensions.github.io/3d-city-models/v0.1.0/schema.json",
  "title": "STAC 3D City Models Extension",
  "description": "STAC Extension for 3D City Model datasets. Defines city3d: prefixed properties for Items and Collections.",
  "oneOf": [
    {
      "$comment": "Validates STAC Items with 3D City Models extension",
      "type": "object",
      "required": ["type", "properties", "stac_extensions"],
      "properties": {
        "type": { "const": "Feature" },
        "stac_extensions": {
          "type": "array",
          "contains": {
            "const": "https://stac-extensions.github.io/3d-city-models/v0.1.0/schema.json"
          }
        },
        "properties": {
          "$ref": "#/definitions/item_fields"
        }
      }
    },
    {
      "$comment": "Validates STAC Collections with 3D City Models extension",
      "type": "object",
      "required": ["type", "stac_extensions"],
      "properties": {
        "type": { "const": "Collection" },
        "stac_extensions": {
          "type": "array",
          "contains": {
            "const": "https://stac-extensions.github.io/3d-city-models/v0.1.0/schema.json"
          }
        },
        "summaries": {
          "$ref": "#/definitions/collection_fields"
        }
      }
    }
  ],
  "definitions": {
    "item_fields": {
      "type": "object",
      "required": ["city3d:encoding"],
      "properties": {
        "city3d:encoding": {
          "title": "3D city model encoding format",
          "type": "string",
          "minLength": 1,
          "examples": ["CityJSON", "CityJSONSeq", "FlatCityBuf", "CityGML"]
        },
        "city3d:version": {
          "title": "Specification version",
          "type": "string",
          "pattern": "^[0-9]"
        },
        "city3d:encoding_version": {
          "title": "Encoding-specific version",
          "type": "string"
        },
        "city3d:city_objects": {
          "title": "Number of city objects",
          "type": "integer",
          "minimum": 0
        },
        "city3d:lods": {
          "title": "Available levels of detail",
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "city3d:co_types": {
          "title": "City object types present",
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "city3d:attributes": {
          "title": "Attribute schema definitions",
          "type": "array",
          "items": {
            "$ref": "#/definitions/attribute_definition"
          }
        },
        "city3d:semantic_surfaces": {
          "title": "Has semantic surface information",
          "type": "boolean"
        },
        "city3d:textures": {
          "title": "Has texture information",
          "type": "boolean"
        },
        "city3d:materials": {
          "title": "Has material information",
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "collection_fields": {
      "type": "object",
      "properties": {
        "city3d:encoding": {
          "title": "All encoding formats in collection",
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "city3d:version": {
          "title": "All versions in collection",
          "type": "array",
          "items": { "type": "string" }
        },
        "city3d:lods": {
          "title": "All LODs across collection",
          "type": "array",
          "items": { "type": "string" }
        },
        "city3d:co_types": {
          "title": "All city object types across collection",
          "type": "array",
          "items": { "type": "string" }
        },
        "city3d:city_objects": {
          "title": "City objects statistics",
          "type": "object",
          "required": ["min", "max", "total"],
          "properties": {
            "min": { "type": "integer", "minimum": 0 },
            "max": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "city3d:semantic_surfaces": {
          "type": "boolean"
        },
        "city3d:textures": {
          "type": "boolean"
        },
        "city3d:materials": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "attribute_definition": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "title": "Attribute name",
          "type": "string",
          "minLength": 1
        },
        "type": {
          "title": "Attribute data type",
          "type": "string",
          "enum": ["STRING", "NUMBER", "BOOLEAN", "DATE", "ARRAY", "OBJECT"]
        },
        "description": {
          "title": "Human-readable description",
          "type": "string"
        },
        "required": {
          "title": "Whether attribute is always present",
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
