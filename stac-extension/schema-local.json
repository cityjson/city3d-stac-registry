{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://localhost:8877/schema-local.json",
  "title": "CityJSON Extension",
  "description": "STAC CityJSON Extension for 3D city model datasets",
  "oneOf": [
    {
      "$comment": "This is the schema for STAC Items.",
      "allOf": [
        {
          "$ref": "#/definitions/stac_extensions"
        },
        {
          "type": "object",
          "required": ["type", "properties", "assets"],
          "properties": {
            "type": {
              "const": "Feature"
            },
            "properties": {
              "allOf": [
                {
                  "$comment": "Require at least cj:encoding",
                  "required": ["cj:encoding"]
                },
                {
                  "$ref": "#/definitions/fields"
                }
              ]
            },
            "assets": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/fields"
              }
            }
          }
        }
      ]
    },
    {
      "$comment": "This is the schema for STAC Collections.",
      "allOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "const": "Collection"
            }
          }
        },
        {
          "$ref": "#/definitions/stac_extensions"
        },
        {
          "type": "object",
          "properties": {
            "summaries": {
              "$ref": "#/definitions/fields"
            }
          }
        }
      ]
    }
  ],
  "definitions": {
    "stac_extensions": {
      "type": "object",
      "required": ["stac_extensions"],
      "properties": {
        "stac_extensions": {
          "type": "array",
          "contains": {
            "const": "http://localhost:8877/schema-local.json"
          }
        }
      }
    },
    "fields": {
      "$comment": "Add your new fields here. Don't require them here, do that above in the corresponding schema.",
      "type": "object",
      "properties": {
        "cj:encoding": {
          "title": "Encoding Format",
          "description": "The CityJSON encoding format",
          "oneOf": [
            {
              "type": "string",
              "enum": ["CityJSON", "CityJSONSeq", "FlatCityBuf", "CityParquet"]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["CityJSON", "CityJSONSeq", "FlatCityBuf", "CityParquet"]
              }
            }
          ]
        },
        "cj:version": {
          "title": "CityJSON Version",
          "description": "CityJSON specification version",
          "type": "string",
          "pattern": "^\\d+\\.\\d+$"
        },
        "cj:city_objects": {
          "title": "City Objects Count",
          "description": "Number of city objects or statistics",
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "object",
              "required": ["min", "max", "total"],
              "properties": {
                "min": {
                  "type": "integer",
                  "minimum": 0
                },
                "max": {
                  "type": "integer",
                  "minimum": 0
                },
                "total": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          ]
        },
        "cj:lods": {
          "title": "Levels of Detail",
          "description": "Available LOD levels",
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d+)?$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "cj:co_types": {
          "title": "City Object Types",
          "description": "City object types present in the dataset (includes extension types prefixed with +)",
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "Building",
                  "BuildingPart",
                  "BuildingInstallation",
                  "BuildingConstructionElement",
                  "BuildingFurniture",
                  "BuildingStorey",
                  "BuildingRoom",
                  "BuildingUnit",
                  "Bridge",
                  "BridgePart",
                  "BridgeInstallation",
                  "BridgeConstructionElement",
                  "BridgeRoom",
                  "BridgeFurniture",
                  "CityFurniture",
                  "CityObjectGroup",
                  "GenericCityObject",
                  "LandUse",
                  "OtherConstruction",
                  "PlantCover",
                  "Railway",
                  "Road",
                  "SolitaryVegetationObject",
                  "TINRelief",
                  "TransportSquare",
                  "Tunnel",
                  "TunnelPart",
                  "TunnelInstallation",
                  "TunnelConstructionElement",
                  "TunnelHollowSpace",
                  "TunnelFurniture",
                  "WaterBody"
                ]
              },
              {
                "$comment": "Extension City Object types start with +",
                "type": "string",
                "pattern": "^\\+.+$"
              }
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "cj:attributes": {
          "title": "Attribute Schema",
          "description": "Schema definitions for semantic attributes",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["String", "Number", "Boolean", "Date", "Array", "Object"]
              },
              "description": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        },
        "cj:transform": {
          "title": "Coordinate Transform",
          "description": "Coordinate transformation parameters for vertex compression",
          "type": "object",
          "required": ["scale", "translate"],
          "properties": {
            "scale": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 3,
              "maxItems": 3
            },
            "translate": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 3,
              "maxItems": 3
            }
          }
        },
        "cj:metadata": {
          "title": "Additional Metadata",
          "description": "Additional metadata from CityJSON file",
          "type": "object",
          "properties": {
            "referenceDate": {
              "type": "string",
              "format": "date"
            },
            "dataSource": {
              "type": "string"
            },
            "geographicalExtent": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 6,
              "maxItems": 6
            },
            "pointOfContact": {
              "type": "object",
              "properties": {
                "contactName": {
                  "type": "string"
                },
                "emailAddress": {
                  "type": "string",
                  "format": "email"
                },
                "phone": {
                  "type": "string"
                },
                "website": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        },
        "cj:extensions": {
          "title": "CityJSON Extensions",
          "description": "URLs to CityJSON extension schemas (Application Domain Extensions)",
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        }
      },
      "patternProperties": {
        "^(?!cj:)": {}
      },
      "additionalProperties": false
    }
  }
}
